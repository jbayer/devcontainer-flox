{
  "name": "Dev Container Example",
  "image": "jbayer/devcontainer-flox:latest",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "flox.flox"
      ]
    }
  },
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=${localEnv:HOME}/.ssh,type=bind,readonly",
    "source=nix-store,target=/nix,type=volume",
    "source=floxuser-home,target=/home/floxuser,type=volume"
  ],
  "postCreateCommand": "echo 'Dev container ready!'",
  "remoteUser": "floxuser"
}
